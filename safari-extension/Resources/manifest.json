{
  "manifest_version": 3,
  "name": "TrustlessSign",
  "version": "1.0.0",
  "description": "Safari Web Extension for TrustlessSign Offline PDF Cryptographic Signature",
  "permissions": [
    "storage",
    "identity",
    "downloads",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "15.4"
    }
  }
}
