{
  "manifest_version": 3,
  "name": "Trust Less Sign",
  "version": "1.6.10",
  "version_name": "1.6.10",
  "key": "",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "description": "Zero-Trust PDF Digital Signature",
  "permissions": [
    "storage",
    "cookies",
    "downloads",
    "windows"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "http://localhost/*",
    "https://tsign.vnot.my.id/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "https://tsign.vnot.my.id/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}